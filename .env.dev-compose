# Env for the containerized dev mode (compose.yml). Copy to .env:
#   cp .env.dev-compose .env
#
# The dev server runs inside a container, so backend URLs use
# host.docker.internal (the Docker host) instead of localhost. Docker Desktop
# resolves that name in the host browser too; on a bare-Linux browser add
# "127.0.0.1 host.docker.internal" to /etc/hosts, or use the pnpm mode.
# The backend stack itself comes from the backend repo: `just up` in api/.

# Public API base URL (no trailing slash). Used by the browser and by SSR
# inside the container; the api dev stack already allows this host.
NEXT_PUBLIC_API_URL=http://host.docker.internal:8000

# IIIF image server (SIPI) base URL, used server-side by the /iiif-proxy rewrite.
NEXT_PUBLIC_IIIF_UPSTREAM=http://host.docker.internal:1024

# Canonical site URL for metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated origins allowed for CORS on /api/* routes.
CORS_ALLOWED_ORIGINS=http://localhost:3000
